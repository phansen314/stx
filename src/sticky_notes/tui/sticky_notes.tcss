Screen {
    layout: vertical;
}

#main-panels {
    height: 1fr;
}

#workspaces-panel {
    width: 25%;
}

#kanban-panel {
    width: 1fr;
}

#kanban-columns {
    height: 1fr;
}

.status-col {
    width: 1fr;
    border-left: solid $surface-lighten-2;
}

.status-col:first-child {
    border-left: none;
}

.status-col-title {
    width: 1fr;
    text-style: bold;
    text-align: center;
    padding: 0 1;
    border-bottom: solid $surface-lighten-2;
}

.task-card {
    padding: 0 1;
}
