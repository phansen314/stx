Screen {
    layout: vertical;
}

Header {
    background: $background;
    color: white;
    text-style: bold;
}

#main-panels {
    height: 1fr;
}

#workspaces-panel {
    width: 25%;
    border: round $surface-lighten-2;
}

#workspaces-tree {
    background: $background;
}

#workspaces-tree:focus {
    background: $background;
    background-tint: transparent;
    tint: transparent;
}

#kanban-panel {
    width: 1fr;
    border: round $surface-lighten-2;
}

#kanban-columns {
    height: 1fr;
}

.status-col {
    width: 1fr;
    border-left: solid $surface-lighten-2;
}

.status-col:first-child {
    border-left: none;
}

.status-col-title {
    width: 1fr;
    text-style: bold;
    text-align: center;
    padding: 0 1;
    border-bottom: solid $surface-lighten-2;
}

.task-card {
    padding: 0 1;
    border: round $surface-lighten-2;
}

.task-card:focus {
    border: round green;
}

#workspaces-tree > .tree--cursor {
    background: green;
}

#workspaces-panel:focus-within {
    border: round green;
}

#kanban-panel:focus-within {
    border: round green;
}

/* ---- Resource selector modal ---- */

NewResourceModal {
    align: center middle;
}

.selector-modal {
    width: 50;
    max-height: 12;
    padding: 1 2;
    border: round green;
    background: $background;
}

/* ---- Shared edit modal styles ---- */

BaseEditModal {
    align: center middle;
}

.modal-container {
    width: 90%;
    max-height: 85%;
    padding: 1 2;
    border: round green;
    background: $background;
}

.modal-id {
    width: 1fr;
    text-style: bold;
    text-align: center;
    margin-bottom: 1;
}

.form-label {
    margin-bottom: 0;
}

.form-field {
    margin-bottom: 1;
}

.form-row {
    height: auto;
}

.form-group {
    width: 1fr;
    margin: 0 1;
    height: auto;
}

.modal-error {
    color: $error;
    text-align: center;
    margin-top: 1;
}

.modal-buttons {
    width: 100%;
    align: center middle;
    height: 3;
    margin-top: 1;
}

.modal-buttons Button {
    margin: 0 1;
}

.dep-info {
    color: $text-muted;
    margin-top: 1;
}

/* ---- Entity-specific overrides ---- */

MarkdownEditor {
    height: 1fr;
}

/* ---- Task metadata modal ---- */

#metadata-rows {
    height: auto;
    max-height: 20;
    margin-bottom: 1;
}

.metadata-row {
    height: 3;
    width: 100%;
    margin-bottom: 0;
}

.metadata-key {
    width: 30%;
    margin-right: 1;
    margin-bottom: 0;
}

.metadata-value {
    width: 1fr;
    margin-right: 1;
    margin-bottom: 0;
}

.metadata-delete {
    width: 5;
    min-width: 5;
}

.metadata-add-row {
    width: 100%;
    height: 3;
    align: left middle;
    margin-bottom: 1;
}
