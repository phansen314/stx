{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stx.local/hook_events.schema.json",
  "title": "stx Hook Event Payload",
  "description": "Schema for the JSON payload delivered on stdin to stx hook commands.",
  "$defs": {
    "taskEntity": {
      "type": "object",
      "required": ["id", "workspace_id", "title", "status_id", "priority", "archived", "created_at", "done", "version"],
      "properties": {
        "id": { "type": "integer" },
        "workspace_id": { "type": "integer" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "description_truncated": { "type": "boolean" },
        "status_id": { "type": "integer" },
        "priority": { "type": "integer" },
        "due_date": { "type": ["integer", "null"] },
        "archived": { "type": "boolean" },
        "created_at": { "type": "integer" },
        "start_date": { "type": ["integer", "null"] },
        "finish_date": { "type": ["integer", "null"] },
        "group_id": { "type": ["integer", "null"] },
        "metadata": { "type": "object" },
        "done": { "type": "boolean" },
        "version": { "type": "integer" }
      }
    },
    "groupEntity": {
      "type": "object",
      "required": ["id", "workspace_id", "title", "archived", "created_at", "version"],
      "properties": {
        "id": { "type": "integer" },
        "workspace_id": { "type": "integer" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "description_truncated": { "type": "boolean" },
        "parent_id": { "type": ["integer", "null"] },
        "archived": { "type": "boolean" },
        "created_at": { "type": "integer" },
        "metadata": { "type": "object" },
        "version": { "type": "integer" }
      }
    },
    "workspaceEntity": {
      "type": "object",
      "required": ["id", "name", "archived", "created_at", "version"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "archived": { "type": "boolean" },
        "created_at": { "type": "integer" },
        "metadata": { "type": "object" },
        "version": { "type": "integer" }
      }
    },
    "statusEntity": {
      "type": "object",
      "required": ["id", "workspace_id", "name", "archived", "created_at", "is_terminal", "version"],
      "properties": {
        "id": { "type": "integer" },
        "workspace_id": { "type": "integer" },
        "name": { "type": "string" },
        "archived": { "type": "boolean" },
        "created_at": { "type": "integer" },
        "is_terminal": { "type": "boolean" },
        "version": { "type": "integer" }
      }
    },
    "edgeEntity": {
      "type": "object",
      "required": ["from_type", "from_id", "to_type", "to_id", "workspace_id", "kind", "acyclic", "metadata", "archived", "version"],
      "properties": {
        "from_type": { "type": "string" },
        "from_id": { "type": "integer" },
        "to_type": { "type": "string" },
        "to_id": { "type": "integer" },
        "workspace_id": { "type": "integer" },
        "kind": { "type": "string" },
        "acyclic": { "type": "boolean" },
        "metadata": { "type": "object" },
        "archived": { "type": "boolean" },
        "version": { "type": "integer" }
      }
    },
    "workspaceRef": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" }
      }
    },
    "changeValue": {
      "type": "object",
      "required": ["old", "new"],
      "properties": {
        "old": {},
        "new": {}
      }
    },
    "eventEnum": {
      "type": "string",
      "enum": [
        "task.created", "task.updated", "task.moved", "task.done", "task.undone",
        "task.archived", "task.transferred", "task.assigned", "task.unassigned",
        "task.meta_set", "task.meta_removed",
        "group.created", "group.updated", "group.archived",
        "group.meta_set", "group.meta_removed",
        "workspace.created", "workspace.updated", "workspace.archived",
        "workspace.meta_set", "workspace.meta_removed",
        "status.created", "status.updated", "status.archived",
        "edge.created", "edge.archived", "edge.updated",
        "edge.meta_set", "edge.meta_removed"
      ]
    }
  },
  "type": "object",
  "required": ["event", "workspace_id", "workspace_name", "entity_type", "entity_id"],
  "properties": {
    "event": { "$ref": "#/$defs/eventEnum" },
    "workspace_id": { "type": ["integer", "null"] },
    "workspace_name": { "type": ["string", "null"] },
    "entity_type": { "type": "string", "enum": ["task", "group", "workspace", "status", "edge"] },
    "entity_id": { "type": ["integer", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event": { "enum": ["task.created", "group.created", "workspace.created", "status.created", "edge.created"] }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["entity", "proposed", "changes"],
        "properties": {
          "changes": { "type": "null" },
          "proposed": { "type": ["object", "null"] },
          "entity": {
            "anyOf": [
              { "$ref": "#/$defs/taskEntity" },
              { "$ref": "#/$defs/groupEntity" },
              { "$ref": "#/$defs/workspaceEntity" },
              { "$ref": "#/$defs/statusEntity" },
              { "$ref": "#/$defs/edgeEntity" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "enum": [
              "task.updated", "task.moved", "task.done", "task.undone",
              "task.assigned", "task.unassigned",
              "group.updated", "workspace.updated", "status.updated", "edge.updated"
            ]
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["entity", "changes", "proposed"],
        "properties": {
          "proposed": { "type": "null" },
          "changes": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/changeValue" }
          },
          "entity": {
            "anyOf": [
              { "$ref": "#/$defs/taskEntity" },
              { "$ref": "#/$defs/groupEntity" },
              { "$ref": "#/$defs/workspaceEntity" },
              { "$ref": "#/$defs/statusEntity" },
              { "$ref": "#/$defs/edgeEntity" }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event": { "enum": ["task.archived", "group.archived", "workspace.archived", "status.archived", "edge.archived"] }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["entity", "changes", "proposed"],
        "properties": {
          "proposed": { "type": "null" },
          "changes": {
            "type": "object",
            "required": ["archived"],
            "properties": {
              "archived": { "$ref": "#/$defs/changeValue" }
            }
          },
          "entity": {
            "anyOf": [
              { "$ref": "#/$defs/taskEntity" },
              { "$ref": "#/$defs/groupEntity" },
              { "$ref": "#/$defs/workspaceEntity" },
              { "$ref": "#/$defs/statusEntity" },
              { "$ref": "#/$defs/edgeEntity" }
            ]
          },
          "archived_task_ids": { "type": "array", "items": { "type": "integer" } },
          "archived_group_ids": { "type": "array", "items": { "type": "integer" } },
          "archived_status_ids": { "type": "array", "items": { "type": "integer" } },
          "reassigned_task_ids": { "type": "array", "items": { "type": "integer" } },
          "reassigned_to": { "type": "integer" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "enum": [
              "task.meta_set", "task.meta_removed",
              "group.meta_set", "group.meta_removed",
              "workspace.meta_set", "workspace.meta_removed",
              "edge.meta_set", "edge.meta_removed"
            ]
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["entity", "meta_key", "meta_value", "changes", "proposed"],
        "properties": {
          "meta_key": { "type": "string" },
          "meta_value": { "type": ["string", "null"] },
          "changes": { "type": "null" },
          "proposed": { "type": "null" },
          "entity": {
            "anyOf": [
              { "$ref": "#/$defs/taskEntity" },
              { "$ref": "#/$defs/groupEntity" },
              { "$ref": "#/$defs/workspaceEntity" },
              { "$ref": "#/$defs/edgeEntity" }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event": { "enum": ["task.transferred"] } },
        "required": ["event"]
      },
      "then": {
        "required": ["entity", "changes", "source_workspace", "target_workspace", "proposed"],
        "properties": {
          "proposed": { "type": "null" },
          "entity": { "$ref": "#/$defs/taskEntity" },
          "changes": {
            "type": "object",
            "required": ["workspace_id", "status_id"],
            "properties": {
              "workspace_id": { "$ref": "#/$defs/changeValue" },
              "status_id": { "$ref": "#/$defs/changeValue" }
            }
          },
          "source_workspace": { "$ref": "#/$defs/workspaceRef" },
          "target_workspace": { "$ref": "#/$defs/workspaceRef" }
        }
      }
    }
  ]
}
