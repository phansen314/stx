#!/usr/bin/env bash
# stx launcher — runs the CLI from any CWD by putting the repo root (which holds cli/ and stxc/)
# on PYTHONPATH. Symlink this onto your PATH if you like: ln -s "$PWD/bin/stx" ~/.local/bin/stx
set -euo pipefail
# Resolve symlinks so `ln -s .../bin/stx ~/.local/bin/stx` finds the real repo root.
self="$(readlink -f "${BASH_SOURCE[0]}")"
here="$(cd "$(dirname "$self")/.." && pwd)"
exec env PYTHONPATH="${here}${PYTHONPATH:+:${PYTHONPATH}}" python3 -m cli "$@"
